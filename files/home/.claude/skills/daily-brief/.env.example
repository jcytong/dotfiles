# Copy to ~/.config/daily-brief/.env and fill in your values (chmod 600).
# The script loads this file automatically; without it, the gather/synthesis
# steps still work, but open-cards, file-cards, sync-sheet, and archive need it.

# Timezone for day-window math and archive filenames. Default: America/New_York.
DAILY_BRIEF_TZ="America/New_York"

# REQUIRED for filing cards: your Fizzy board id. Get it from `fizzy board list`.
DAILY_BRIEF_FIZZY_BOARD_ID=""
# The board's "In Progress" column id (board-specific). If unset, the pseudo
# id "in-progress" is used, which fizzy also accepts.
DAILY_BRIEF_FIZZY_IN_PROGRESS_COLUMN_ID=""

# REQUIRED for archiving: the Obsidian vault dir briefs are written to.
# ~ and $HOME are expanded.
DAILY_BRIEF_VAULT_DIR="$HOME/Documents/obsidian-vaults/your-vault/daily-brief"

# OPTIONAL: sync-sheet defaults. Leave blank to require --spreadsheet-id/--owner
# on each `sync-sheet` call.
DAILY_BRIEF_SHEET_ID=""
DAILY_BRIEF_SHEET_TAB=""
DAILY_BRIEF_SHEET_GID=""
DAILY_BRIEF_SHEET_OWNER=""
